ADMIN_TOKEN=replace-with-a-long-random-token
APP_SECRET=replace-with-a-long-random-secret
PUBLIC_BASE_URL=http://127.0.0.1:8000
# Production: use a persistent PostgreSQL connection string (for example Neon).
DATABASE_URL=
# Local/test fallback when DATABASE_URL is empty.
DATABASE_PATH=./data/ctr.db
RETENTION_DAYS=90
FREE_ACCESS_MODE=true

# Optional voluntary-support provider URL. Leave empty until a provider/account is ready.
SUPPORT_URL=
SUPPORT_PROJECT_NAME=ChinaTradeResolve

# Optional OpenAI structured triage. Rules-only mode works without these.
ENABLE_AI_TRIAGE=false
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TIMEOUT_SECONDS=20


# HTTPS email bridge (recommended for Render Free).
EMAIL_BRIDGE_URL=
EMAIL_BRIDGE_SECRET=
EMAIL_BRIDGE_TIMEOUT_SECONDS=20

# Gmail SMTP for confirmations and operator alerts.
# Never put the normal Google Account password here.
CONTACT_EMAIL=chinatraderesolve.support@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=chinatraderesolve.support@gmail.com
SMTP_PASSWORD=
SMTP_FROM=ChinaTradeResolve <chinatraderesolve.support@gmail.com>
ADMIN_EMAIL=chinatraderesolve.support@gmail.com
