# ChinaTradeResolve local/Render environment template.
# Never commit real passwords, API keys, private keys or recovery phrases.

# Database: Render normally supplies DATABASE_URL. SQLite is for local testing.
DATABASE_URL=
DATABASE_PATH=./data/ctr.db

# Required for administrator access. Use different random values, 32+ characters each.
ADMIN_TOKEN=
APP_SECRET=

# Optional custom domain. Leave blank on Render to use RENDER_EXTERNAL_URL automatically.
PUBLIC_BASE_URL=

# Public launch mode is fail-closed. Enable it only after /ready returns 200.
PUBLIC_LAUNCH_MODE=false
FREE_ACCESS_MODE=true
RETENTION_DAYS=90
INACTIVE_RETENTION_DAYS=365
MAINTENANCE_INTERVAL_SECONDS=60
RETENTION_CHECK_INTERVAL_SECONDS=86400

# OpenAI features. Keep the global billing switch false until the API account is funded.
# After payment, set OPENAI_BILLING_READY=true to allow the individually enabled features.
OPENAI_BILLING_READY=false
OPENAI_API_KEY=
OPENAI_MODEL=
ENABLE_AI_TRIAGE=false
APPLICATION_TRIAGE_TIMEOUT_SECONDS=8
ENABLE_AI_ASSISTANT=false
OPENAI_ASSISTANT_MODEL=
AI_ASSISTANT_MAX_OUTPUT_TOKENS=500
AI_ASSISTANT_HISTORY_MESSAGES=8
MAX_DAILY_AI_ASSISTANT_REQUESTS=40
ENABLE_VOICE_INPUT=true
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
VOICE_MAX_SECONDS=120
MAX_DAILY_VOICE_TRANSCRIPTIONS=20
OPENAI_TIMEOUT_SECONDS=20
OPENAI_MODERATION_MODEL=omni-moderation-latest
ENABLE_DOCUMENT_ANALYSIS=false
OPENAI_DOCUMENT_MODEL=
DOCUMENT_ANALYSIS_MAX_OUTPUT_TOKENS=6000
DOCUMENT_ANALYSIS_TIMEOUT_SECONDS=90
DOCUMENT_PDF_DETAIL=low
MAX_DAILY_DOCUMENT_ANALYSES=20

# Optional public-form bot protection. Configure both values or neither.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Real operator identity for the privacy notice and compliance records.
DATA_CONTROLLER_NAME=
DATA_CONTROLLER_ADDRESS=
DATA_CONTROLLER_REGISTRATION=
OPERATOR_PROFILE=
OPERATOR_CREDENTIALS=

# Contact details.
CONTACT_EMAIL=chinatraderesolve.support@gmail.com
ADMIN_EMAIL=chinatraderesolve.support@gmail.com

# Email delivery is disabled until SMTP_HOST or the bridge settings are filled.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ChinaTradeResolve <chinatraderesolve.support@gmail.com>
EMAIL_BRIDGE_URL=
EMAIL_BRIDGE_SECRET=
EMAIL_BRIDGE_TIMEOUT_SECONDS=20

# Voluntary support. The PayPal link is public and contains no secret.
ENABLE_VOLUNTARY_SUPPORT=true
PAYPAL_SUPPORT_URL=https://www.paypal.com/ncp/payment/THKQMZDRRNHQ8
# Optional additional external provider.
SUPPORT_URL=
SUPPORT_PROJECT_NAME=ChinaTradeResolve
BTC_ADDRESS=1KPw94sUBeJH3noxdgQWrVMQf3sAebmeN4
ETH_ADDRESS=0x2F8a2773F8254d061ef286Bac8BF922344a2A494
USDT_TRC20_ADDRESS=TEJaGC38ZV8UirP7zkfPRiqHRi73wTWX5R
SOL_ADDRESS=AEZsJ2921CR7qD7kRQRS7BiaxneeaFyKMhwDmyjCS6Zm

# Set only behind a trusted non-Render reverse proxy. Render sets RENDER=true itself.
TRUST_PROXY_HEADERS=false
